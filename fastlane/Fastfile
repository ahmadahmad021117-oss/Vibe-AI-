default_platform(:ios)

platform :ios do
  desc "Generate the Xcode project and resolve Swift Package dependencies."
  lane :prepare do
    sh("cd .. && xcodegen generate")
    sh(
      "cd .. && xcodebuild -resolvePackageDependencies " \
      "-project VibeNutrition.xcodeproj -scheme VibeNutrition"
    )
  end

  desc <<~DESC
    Build a Release archive and upload it to TestFlight.

    Required environment:
      - APP_STORE_CONNECT_API_KEY_KEY_ID
      - APP_STORE_CONNECT_API_KEY_ISSUER_ID
      - APP_STORE_CONNECT_API_KEY_KEY (base64-encoded contents of the .p8)

    Optional environment:
      - BUILD_NUMBER     (default: minute-precision timestamp)
      - BETA_CHANGELOG   (default: "Internal build.")

    DEVELOPMENT_TEAM in project.yml must be set or the archive step will fail.
  DESC
  lane :beta do
    ensure_env_vars(
      env_vars: %w[
        APP_STORE_CONNECT_API_KEY_KEY_ID
        APP_STORE_CONNECT_API_KEY_ISSUER_ID
        APP_STORE_CONNECT_API_KEY_KEY
      ]
    )

    prepare

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
      is_key_content_base64: true
    )

    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    build_app(
      project: "VibeNutrition.xcodeproj",
      scheme: "VibeNutrition",
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["BETA_CHANGELOG"] || "Internal build."
    )
  end
end
